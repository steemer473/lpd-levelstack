{
  "name": "lpd-levelstack",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build:tokens": "node scripts/build-design-tokens.mjs",
    "prepare": "pnpm build:tokens",
    "predev": "pnpm build:tokens",
    "dev": "next dev --port 3001",
    "prebuild": "pnpm build:tokens",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:customer-copy": "node scripts/lint-customer-copy.mjs",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test e2e/report-mobile.spec.ts",
    "verify:env": "node scripts/verify-vercel-env.mjs --from-local",
    "verify:research": "node scripts/verify-research-keys.mjs",
    "setup:ghl-fields": "node scripts/setup-ghl-levelstack-fields.mjs --from-local",
    "generate:ghl-emails": "npx tsx scripts/generate-ghl-email-templates.mjs",
    "generate:nurture-emails": "node scripts/sync-plunk-templates.mjs",
    "sync:plunk-templates": "node scripts/sync-plunk-templates.mjs --from-local",
    "setup:plunk-workflows": "node scripts/setup-plunk-workflows.mjs --from-local",
    "setup:plunk-analytics-webhooks": "node scripts/setup-plunk-analytics-webhooks.mjs --from-local",
    "import:ghl-emails": "node scripts/import-ghl-email-templates.mjs --from-local",
    "paste:ghl-emails": "node scripts/ghl-email-paste-helper.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.107.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.77.0",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  }
}
