        "lineHeight": { "$value": "1.35", "$type": "number" }
      },
      "body": {
        "fontFamily": { "$value": "sans", "$type": "string", "$description": "Use --font-sans" },
        "fontSize": { "$value": "1rem", "$type": "dimension", "$description": "fontSize.base" },
        "fontWeight": { "$value": "400", "$type": "fontWeight" },
        "lineHeight": { "$value": "1.6", "$type": "number", "$description": "lineHeight.body / .line-spacing-consistent" }
