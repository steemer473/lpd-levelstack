      "heroHeading": {
        "$value": "linear-gradient(to right, hsl(14, 100%, 60%), rgba(255,255,255,0.9), hsl(193, 100%, 50%))",
        "$type": "string",
        "$description": "Homepage H1 text gradient (bg-gradient-to-r equivalent)"
