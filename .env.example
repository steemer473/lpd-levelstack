# Public (client)
NEXT_PUBLIC_APP_URL=http://localhost:3001
# Hub must set NEXT_PUBLIC_LEVELSTACK_APP_URL to this URL for account/checkout CTAs
NEXT_PUBLIC_HUB_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — same Supabase project as lpd-redesign
SUPABASE_SERVICE_ROLE_KEY=

# Local testing only — allows /intake without a hub order (never enable on Vercel)
# LEVELSTACK_DEV_BYPASS_ENTITLEMENT=true
# LEVELSTACK_DEV_SKIP_WEBSITE_CHECK=true
# LEVELSTACK_DEV_REPLACE_SNAPSHOT=true
# LEVELSTACK_DEV_MOCK_SERP=true   # zero-cost SERP fixtures (never on Vercel)

# Phase 2.1 — research + synthesis (required on Vercel Production)
# At least one SERP provider:
# SERPAPI_KEY=
# SEARCHAPI_KEY=
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=
# SERP_PROVIDER_CHAIN=searchapi,dataforseo,serpapi
# SERP_CACHE_TTL_HOURS=24
# OPENAI_API_KEY=
# FIRECRAWL_API_KEY=   # optional; website scrape + firecrawl-mcp
# GOOGLE_PAGESPEED_API_KEY=   # optional; higher PSI quota

# GoHighLevel — lead sync (same as lpd-redesign); optional mirror after Plunk pivot
# GHL_API_KEY=
# GHL_LOCATION_ID=
# GHL_SYNC_ENABLED=true   # set false to skip GHL upsert (Plunk handles nurture)

# Plunk — nurture emails (Workflow A & B)
# PLUNK_SECRET_KEY=
# PLUNK_PUBLIC_KEY=
# PLUNK_FROM_EMAIL=notify@notify.levelplaydigital.com
# PLUNK_FROM_NAME=LevelStack
# PLUNK_WEBHOOK_SECRET=
# PLUNK_API_URL=https://next-api.useplunk.com
# PLUNK_WORKFLOW_API_URL=https://next-api.useplunk.com

# Phase 3+ (optional)
# RESEND_API_KEY=
# FROM_EMAIL=
# FROM_NAME=
# LEVELSTACK_ADMIN_NOTIFY_EMAIL=
# ANTHROPIC_API_KEY=

# Vercel Production examples (see docs/vercel.md):
# NEXT_PUBLIC_APP_URL=https://levelstack.levelplaydigital.com
# NEXT_PUBLIC_HUB_URL=https://levelplaydigital.com
