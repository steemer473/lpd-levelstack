# Public (client)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Hub must set NEXT_PUBLIC_LEVELSTACK_APP_URL to this URL for account/checkout CTAs
NEXT_PUBLIC_HUB_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — same Supabase project as lpd-redesign
SUPABASE_SERVICE_ROLE_KEY=

# Local testing only — allows /intake without a hub order (never enable in production)
# LEVELSTACK_DEV_BYPASS_ENTITLEMENT=true

# Phase 2.1 — research + synthesis (required for live reports)
# SERPAPI_KEY=
# OPENAI_API_KEY=
# FIRECRAWL_API_KEY=   # optional; website scrape + firecrawl-mcp (see .cursor/mcp.example.json)
# GOOGLE_PAGESPEED_API_KEY=   # optional; higher PSI quota (mobile Lighthouse score)

# Phase 3+ (optional)
# RESEND_API_KEY=
# FROM_EMAIL=
# FROM_NAME=
# ANTHROPIC_API_KEY=
